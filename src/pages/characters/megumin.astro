---
import SpellCardLayout from "../../layouts/SpellCardLayout.astro";
import { type CollectionEntry } from "astro:content";

const characterSpellNameList: CollectionEntry<"spells">["data"]["spell"][0]["name"][] =
  [
    // Cantrips: 3 + 2 (initiate)
    "Fire Bolt",
    "Shocking Grasp",
    "Minor Illusion",
    "Mage Hand",
    "Mold Earth",
    "Prestidigitation", // elf
    // Spellbook: 14 + 1 (initiate) + 2 (evoker)
    //   rituals OR in book
    "Leomund's Tiny Hut",
    "Comprehend Languages",
    "Find Familiar",
    "Identify",
    "Alarm",
    "Flaming Sphere",
    "Thunderwave",
    "Sleep",
    "Silvery Barbs",
    "Fly",
    //   prepared spells 9 + 1 (initiate) + 2 (high elf)
    "Mage Armor", // initiate
    "Detect Magic", // High elf
    "Misty Step", // High Elf
    "Shield",
    "Spellfire Flare",
    "Dragon's Breath",
    "Scorching Ray", // evoker
    "Shatter", // evoker
    "Invisibility",
    "Fireball",
    "Counterspell",
    "Lightning Bolt",
  ];
---

<SpellCardLayout
  characterSpellNameList={characterSpellNameList}
  characterName="Megumin"
/>
