    "True Strike",
    "Minor Illusion",
    "Shield",
    // 1. druidic
    "Speak with Animals",
    // 1. primal order: Magician
    "Druidcraft",
    // 2. Wild Companion
    "Find Familiar",
    // 3. Starmap
    "Guidance",
    "Guiding Bolt",
    // 4. Telekinetic
    "Mage Hand",
    // cantrips: 3
    "Elementalism",
    "Starry Wisp",
    "Thorn Whip",
    // prepared spells: 9
    "Healing Word",
    "Aid",
    "Speak with Plants",
    "Wither and Bloom",
    "Enlarge/Reduce",
    "Elemental Weapon",
    "Call Lightning",
    "Summon Fey",
    "Detect Magic",
