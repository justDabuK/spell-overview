---
import SpellCardLayout from "../../layouts/SpellCardLayout.astro";
import { type CollectionEntry } from "astro:content";

const characterSpellNameList: CollectionEntry<"spells">["data"]["spell"][0]["name"][] =
  [
    // Drow
    "Dancing Lights",
    "Faerie Fire",
    "Darkness",
    // prepared spells: 6
    "Bless",
    "Searing Smite",
    "Command",
    "Shield of Faith",
    "Aid",
    "Zone of Truth",
    // paladin's smite
    "Divine Smite",
    // faithful steed
    "Find Steed",
    // vengeance
    "Bane",
    "Hunter's Mark",
    "Hold Person",
    "Misty Step",
  ];
---

<SpellCardLayout
  characterSpellNameList={characterSpellNameList}
  characterName="Elf Paladin"
/>
